#!/usr/bin/env bash
#
# deploy-build
#
# Validate the latest local build, upload its Mender Artifact, and create a
# deployment for a configured device.
#
# Prerequisite:
#   source scripts/setup-env
#
# Usage:
#   deploy-build [options]
#
# Options:
#   -d, --device-id <id>        Override DEVICE_MENDER_ID
#   -n, --name <name>           Override deployment name
#   -s, --skip-upload           Skip Artifact upload
#   -y, --yes                   Do not ask for confirmation
#   -v, --verify                Verify SHA256 and Artifact name before upload
#   -h, --help                  Show this help
#

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

DEVICE_ID="${DEVICE_MENDER_ID:-}"
DEPLOYMENT_NAME=""
SKIP_UPLOAD=false
ASSUME_YES=false
VERIFY_BUILD=false

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

error() {
    echo "Error: $*" >&2
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [options]

Upload the latest local Mender Artifact and deploy it to a device.

Options:
  -d, --device-id <id>        Override DEVICE_MENDER_ID
  -n, --name <name>           Override deployment name
  -s, --skip-upload           Skip Artifact upload
  -y, --yes                   Do not ask for confirmation
  -v, --verify                Verify SHA256 and Artifact name before upload
  -h, --help                  Show this help

Examples:
  $(basename "$0")
  $(basename "$0") --verify
  $(basename "$0") --device-id DEVICE_ID
  $(basename "$0") --skip-upload --yes
EOF
}

require_variable() {
    local variable_name="$1"

    if [[ -z "${!variable_name:-}" ]]; then
        error "${variable_name} is not set."
        return 1
    fi
}

confirm() {
    local answer

    if [[ "${ASSUME_YES}" == true ]]; then
        return 0
    fi

    read -r -p "Continue? [y/N] " answer

    [[ "${answer}" =~ ^[Yy]$ ]]
}

api_request() {
    local method="$1"
    local url="$2"
    local response_file="$3"
    shift 3

    curl \
        --silent \
        --show-error \
        --location \
        --request "${method}" \
        --connect-timeout 15 \
        --max-time 600 \
        --retry 3 \
        --retry-delay 2 \
        --retry-all-errors \
        --output "${response_file}" \
        --write-out '%{http_code}' \
        "$@" \
        "${url}"
}

print_response_on_error() {
    local response_file="$1"

    if [[ -s "${response_file}" ]]; then
        echo "Server response:" >&2

        if jq -e . "${response_file}" >/dev/null 2>&1; then
            jq . "${response_file}" >&2
        else
            cat "${response_file}" >&2
            echo >&2
        fi
    fi
}

# ---------------------------------------------------------------------------
# Parse options
# ---------------------------------------------------------------------------

while (($# > 0)); do
    case "$1" in
        -d | --device-id)
            [[ $# -ge 2 ]] || {
                error "$1 requires an argument."
                exit 1
            }
            DEVICE_ID="$2"
            shift 2
            ;;
        -n | --name)
            [[ $# -ge 2 ]] || {
                error "$1 requires an argument."
                exit 1
            }
            DEPLOYMENT_NAME="$2"
            shift 2
            ;;
        -s | --skip-upload)
            SKIP_UPLOAD=true
            shift
            ;;
        -y | --yes)
            ASSUME_YES=true
            shift
            ;;
        -v | --verify)
            VERIFY_BUILD=true
            shift
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            error "Unknown option: $1"
            usage >&2
            exit 1
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Validate environment
# ---------------------------------------------------------------------------

require_variable SCRIPTS_DIR || {
    error "Run 'source scripts/setup-env' first."
    exit 1
}

require_variable MENDER_SERVER_URL || exit 1
require_variable MENDER_ACCESS_TOKEN || {
    error "Configure MENDER_ACCESS_TOKEN in certificates/secrets.conf."
    exit 1
}

if [[ -z "${DEVICE_ID}" ]]; then
    error "DEVICE_MENDER_ID is not set."
    error "Configure it in project.conf or pass --device-id."
    exit 1
fi

if ! command -v curl >/dev/null 2>&1; then
    error "curl is required."
    exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
    error "jq is required."
    exit 1
fi

CHECK_BUILD_LIBRARY="${SCRIPTS_DIR}/check-build"

if [[ ! -f "${CHECK_BUILD_LIBRARY}" ]]; then
    error "check-build was not found:"
    error "  ${CHECK_BUILD_LIBRARY}"
    exit 1
fi

# shellcheck source=/dev/null
source "${CHECK_BUILD_LIBRARY}"

if [[ "${VERIFY_BUILD}" == true ]]; then
    check_build_verify
else
    check_build_load
    check_build_validate_paths
    check_build_validate_sizes
fi

# ---------------------------------------------------------------------------
# Resolve deployment information
# ---------------------------------------------------------------------------

MENDER_SERVER_URL="${MENDER_SERVER_URL%/}"

if [[ -z "${DEPLOYMENT_NAME}" ]]; then
    DEPLOYMENT_NAME="deploy-${BUILD_ARTIFACT_NAME}"
fi

UPLOAD_URL="${MENDER_SERVER_URL}/api/management/v1/deployments/artifacts"
DEPLOY_URL="${MENDER_SERVER_URL}/api/management/v1/deployments/deployments"

echo
echo "Deploy local build"
echo "=================="
printf "  %-24s %s\n" "MENDER_SERVER_URL:" "${MENDER_SERVER_URL}"
printf "  %-24s %s\n" "DEVICE_MENDER_ID:" "${DEVICE_ID}"
printf "  %-24s %s\n" "BUILD_ARTIFACT_NAME:" "${BUILD_ARTIFACT_NAME}"
printf "  %-24s %s\n" "BUILD_ARTIFACT_FILE:" "${BUILD_ARTIFACT_FILE}"
printf "  %-24s %s\n" "DEPLOYMENT_NAME:" "${DEPLOYMENT_NAME}"
printf "  %-24s %s\n" "SKIP_UPLOAD:" "${SKIP_UPLOAD}"
echo

if ! confirm; then
    echo "Cancelled."
    exit 0
fi

# ---------------------------------------------------------------------------
# Upload Artifact
# ---------------------------------------------------------------------------

response_file="$(mktemp)"
payload_file="$(mktemp)"

cleanup() {
    rm -f "${response_file}" "${payload_file}"
}

trap cleanup EXIT

if [[ "${SKIP_UPLOAD}" != true ]]; then
    echo
    echo "Uploading Artifact..."

    http_status="$(
        api_request \
            POST \
            "${UPLOAD_URL}" \
            "${response_file}" \
            -H "Authorization: Bearer ${MENDER_ACCESS_TOKEN}" \
            -F "artifact=@${BUILD_ARTIFACT_FILE}"
    )"

    case "${http_status}" in
        2??)
            echo "Artifact upload completed."
            ;;
        409)
            echo "Artifact already exists on the server; continuing."
            ;;
        *)
            error "Artifact upload failed with HTTP ${http_status}."
            print_response_on_error "${response_file}"
            exit 1
            ;;
    esac
else
    echo
    echo "Artifact upload skipped."
fi

# ---------------------------------------------------------------------------
# Create deployment
# ---------------------------------------------------------------------------

jq -n \
    --arg name "${DEPLOYMENT_NAME}" \
    --arg artifact_name "${BUILD_ARTIFACT_NAME}" \
    --arg device_id "${DEVICE_ID}" \
    '{
        name: $name,
        artifact_name: $artifact_name,
        devices: [$device_id]
    }' >"${payload_file}"

: >"${response_file}"

echo
echo "Creating deployment..."

http_status="$(
    api_request \
        POST \
        "${DEPLOY_URL}" \
        "${response_file}" \
        -H "Authorization: Bearer ${MENDER_ACCESS_TOKEN}" \
        -H "Content-Type: application/json" \
        --data-binary "@${payload_file}"
)"

case "${http_status}" in
    2??)
        echo "Deployment created successfully."
        ;;
    *)
        error "Deployment creation failed with HTTP ${http_status}."
        print_response_on_error "${response_file}"
        exit 1
        ;;
esac

DEPLOYMENT_ID=""

if [[ -s "${response_file}" ]] &&
    jq -e . "${response_file}" >/dev/null 2>&1; then
    DEPLOYMENT_ID="$(
        jq -r '.id // .deployment_id // empty' "${response_file}"
    )"
fi

echo
echo "Deployment submitted"
echo "===================="
printf "  %-24s %s\n" "DEPLOYMENT_NAME:" "${DEPLOYMENT_NAME}"
printf "  %-24s %s\n" "BUILD_ARTIFACT_NAME:" "${BUILD_ARTIFACT_NAME}"
printf "  %-24s %s\n" "DEVICE_MENDER_ID:" "${DEVICE_ID}"

if [[ -n "${DEPLOYMENT_ID}" ]]; then
    printf "  %-24s %s\n" "DEPLOYMENT_ID:" "${DEPLOYMENT_ID}"
fi

echo
